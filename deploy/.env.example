BACKEND_IMAGE=ghcr.io/your-org/dms-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org/dms-frontend:latest

FRONTEND_PORT=8080
BACKEND_PORT=3000
DB_PORT_EXTERNAL=1433
ES_PORT_EXTERNAL=9200
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001

DB_USER=sa
DB_PASS=ChangeThisStrongPassword!2026
DB_NAME=DMS
DB_ENCRYPT=false
DB_TRUST_CERT=true

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
JWT_ACCESS_EXPIRES_IN_SEC=86400
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

AUTH_LOGIN_BLOCK_AFTER=5
AUTH_LOGIN_BLOCK_SEC=900
AUTH_LOGIN_RESET_WINDOW_SEC=3600

BOOTSTRAP_TOKEN=replace_with_a_long_bootstrap_token
ALLOWED_EMAIL_DOMAIN=bsm.com.mx
EMAIL_MODE=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=no-reply@example.com
SMTP_USER=
SMTP_PASS=

CORS_ORIGIN=http://localhost:8080
FEATURE_FLAGS=audit-json-export,admin-analytics,notifications,saved-views,advanced-exports,dark-mode,i18n
CSP_ENABLED=true
CSP_DEFAULT_SRC="'self'"
CSP_CONNECT_SRC="'self',http://localhost:8080,http://localhost:3000"
CSP_IMG_SRC="'self',data:,blob:"
CSP_STYLE_SRC="'self','unsafe-inline'"
CSP_FONT_SRC="'self',data:"
CSP_SCRIPT_SRC="'self'"

MAX_FILE_SIZE_MB=20
UPLOAD_ORIGINAL_NAME_MAX_LENGTH=180
ALLOWED_EXTENSIONS=".pdf,.docx,.xlsx"
ALLOWED_MIME_TYPES="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"

SEARCH_MODE=auto
ES_INDEX_DOCUMENTS=dms_documents
SEARCH_INDEX_MAX_RETRIES=5
SEARCH_INDEX_RETRY_BASE_MS=2000
SEARCH_INDEX_RETRY_MAX_MS=30000
SEARCH_INDEX_WORKER_MS=3000
SEARCH_INDEX_BATCH_SIZE=10
OCR_ENABLED=true
OCR_TESSERACT_BIN=tesseract
OCR_PDFTOPPM_BIN=pdftoppm
OCR_LANGS=spa+eng
OCR_DPI=300
OCR_MAX_PAGES=10
OCR_TIMEOUT_MS=120000

LOG_FORMAT=json
LOG_FILE_PATH=/app/runtime/logs/backend.log
HTTP_SLOW_REQUEST_MS=1000

GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me
