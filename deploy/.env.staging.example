BACKEND_IMAGE=ghcr.io/your-org/dms-backend:staging-latest
FRONTEND_IMAGE=ghcr.io/your-org/dms-frontend:staging-latest

FRONTEND_PORT=8081
BACKEND_PORT=3002
DB_PORT_EXTERNAL=1434
ES_PORT_EXTERNAL=9201
PROMETHEUS_PORT=9091
LOKI_PORT=3101
GRAFANA_PORT=3002

DB_USER=sa
DB_PASS=REPLACE_WITH_STAGING_SQL_PASSWORD
DB_NAME=DMS_STAGING
DB_ENCRYPT=false
DB_TRUST_CERT=true

JWT_SECRET=REPLACE_WITH_STAGING_JWT_SECRET_32_CHARS_MIN
JWT_EXPIRES_IN=1d
JWT_ACCESS_EXPIRES_IN_SEC=86400
JWT_REFRESH_SECRET=REPLACE_WITH_STAGING_REFRESH_SECRET_32_CHARS_MIN
JWT_REFRESH_EXPIRES_IN=7d

BOOTSTRAP_TOKEN=REPLACE_WITH_STAGING_BOOTSTRAP_TOKEN
ALLOWED_EMAIL_DOMAIN=bsm.com.mx
EMAIL_MODE=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=no-reply@example.com
SMTP_USER=
SMTP_PASS=

CORS_ORIGIN=https://staging.example.com
FEATURE_FLAGS=audit-json-export,admin-analytics,notifications,saved-views,advanced-exports,dark-mode,i18n
LOG_FORMAT=json
LOG_FILE_PATH=/app/runtime/logs/backend.log
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD
