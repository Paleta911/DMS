BACKEND_IMAGE=ghcr.io/your-org/dms-backend:production-latest
FRONTEND_IMAGE=ghcr.io/your-org/dms-frontend:production-latest

FRONTEND_PORT=8080
BACKEND_PORT=3000
DB_PORT_EXTERNAL=1433
ES_PORT_EXTERNAL=9200
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001

DB_USER=sa
DB_PASS=ChangeThisProductionPassword!2026
DB_NAME=DMS
DB_ENCRYPT=true
DB_TRUST_CERT=true

JWT_SECRET=replace_with_a_long_random_production_secret
JWT_EXPIRES_IN=1d
JWT_ACCESS_EXPIRES_IN_SEC=86400
JWT_REFRESH_SECRET=replace_with_a_different_production_secret
JWT_REFRESH_EXPIRES_IN=7d

BOOTSTRAP_TOKEN=replace_with_a_production_bootstrap_token
ALLOWED_EMAIL_DOMAIN=bsm.com.mx
EMAIL_MODE=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=no-reply@example.com
SMTP_USER=
SMTP_PASS=

CORS_ORIGIN=https://dms.example.com
FEATURE_FLAGS=audit-json-export,admin-analytics,notifications,saved-views,advanced-exports,dark-mode,i18n
LOG_FORMAT=json
LOG_FILE_PATH=/app/runtime/logs/backend.log
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me
