BACKEND_IMAGE=ghcr.io/your-org/dms-backend:production-latest
FRONTEND_IMAGE=ghcr.io/your-org/dms-frontend:production-latest

FRONTEND_PORT=8080
BACKEND_PORT=3000
DB_PORT_EXTERNAL=1433
ES_PORT_EXTERNAL=9200
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001

DB_USER=sa
DB_PASS=REPLACE_WITH_PRODUCTION_SQL_PASSWORD
DB_NAME=DMS
DB_ENCRYPT=true
DB_TRUST_CERT=true

JWT_SECRET=REPLACE_WITH_PRODUCTION_JWT_SECRET_32_CHARS_MIN
JWT_EXPIRES_IN=1d
JWT_ACCESS_EXPIRES_IN_SEC=86400
JWT_REFRESH_SECRET=REPLACE_WITH_PRODUCTION_REFRESH_SECRET_32_CHARS_MIN
JWT_REFRESH_EXPIRES_IN=7d

BOOTSTRAP_TOKEN=REPLACE_WITH_PRODUCTION_BOOTSTRAP_TOKEN
ALLOWED_EMAIL_DOMAIN=bsm.com.mx
EMAIL_MODE=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=no-reply@example.com
SMTP_USER=
SMTP_PASS=

CORS_ORIGIN=https://dms.example.com
FEATURE_FLAGS=audit-json-export,admin-analytics,notifications,saved-views,advanced-exports,dark-mode,i18n
LOG_FORMAT=json
LOG_FILE_PATH=/app/runtime/logs/backend.log
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD
