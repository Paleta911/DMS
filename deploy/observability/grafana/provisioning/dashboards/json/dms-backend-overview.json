      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(dms_http_requests_total{status_class=~\"4xx|5xx\"}[5m])) / clamp_min(sum(rate(dms_http_requests_total[5m])), 0.0001)",
          "refId": "A"
        }
      ],
      "title": "Tasa de error",
      "type": "stat"
