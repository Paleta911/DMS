{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "start:worker": "ts-node -r tsconfig-paths/register src/worker.ts",
    "start:worker:prod": "node dist/src/worker.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "db:migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/data-source.ts",
    "db:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "db:migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/data-source.ts",
    "db:migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/src/data-source.js",
    "db:migration:revert:prod": "node ./node_modules/typeorm/cli.js migration:revert -d dist/src/data-source.js",
    "db:analyze": "node scripts/analyze-db-hotspots.mjs",
    "db:ensure": "node scripts/ensure-db.mjs",
    "db:seed": "ts-node -r tsconfig-paths/register scripts/seed.ts",
    "db:reset:dev": "ts-node -r tsconfig-paths/register scripts/db-reset-dev.ts",
    "documents:reprocess-content": "ts-node -r tsconfig-paths/register scripts/reprocess-document-content.ts",
    "storage:backup": "node scripts/backup-uploads.mjs",
    "storage:restore": "node scripts/restore-uploads.mjs",
    "storage:verify": "node scripts/verify-uploads-backup.mjs",
    "check:deps": "node scripts/check-deps.mjs",
    "infra:wait:db": "node scripts/wait-for-infra.mjs --db",
    "infra:wait:search": "node scripts/wait-for-infra.mjs --search",
    "infra:up": "docker compose --profile db up -d",
    "infra:up:db": "docker compose --profile db up -d sqlserver",
    "infra:up:search": "docker compose up -d elasticsearch kibana",
    "infra:down": "docker compose down",
    "dev:prepare": "npm run infra:wait:db && npm run db:ensure && npm run db:migration:run && npm run check:deps",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:smoke:registration": "node scripts/smoke-test-registration.mjs",
    "test:smoke:elastic": "node scripts/smoke-test-elastic.mjs",
    "test:smoke:ocr": "node scripts/smoke-test-ocr.mjs",
    "test:ci:local": "node scripts/ci-local.mjs",
    "test:ci:local:strict": "node scripts/ci-local.mjs --strict",
    "docs:openapi:export": "ts-node -r tsconfig-paths/register scripts/export-openapi.ts",
    "docs:openapi:check": "node scripts/check-openapi.mjs",
    "docs:openapi:update": "node scripts/check-openapi.mjs --write",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "e2e:install": "playwright install chromium",
    "e2e:prepare": "node scripts/e2e-prepare.mjs",
    "e2e:serve:backend": "npm run start:prod",
    "e2e:serve:frontend": "npm --prefix ../frontend run preview -- --host 127.0.0.1 --port 4173",
    "test:e2e:browser": "npm run e2e:prepare && playwright test"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.13.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/elasticsearch": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "mammoth": "^1.6.0",
    "mssql": "^12.2.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.54.2",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
