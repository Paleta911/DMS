NODE_ENV=development
APP_RUNTIME_ROLE=both
PORT=3000
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASS=your_password
MSSQL_SA_PASSWORD=DmsDevPass!2026
DB_NAME=DMS
DB_ENCRYPT=false
DB_TRUST_CERT=true
DB_SYNC=false
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=1d
JWT_ACCESS_EXPIRES_IN_SEC=86400
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
UPLOAD_DIR=./uploads
BACKUP_DIR=./backups
MAX_FILE_SIZE_MB=20
UPLOAD_ORIGINAL_NAME_MAX_LENGTH=180
ALLOWED_EXTENSIONS=.pdf,.docx,.xlsx
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
CORS_ORIGIN=*
LOG_FORMAT=pretty
LOG_FILE_PATH=
HTTP_SLOW_REQUEST_MS=1000
CSP_ENABLED=true
CSP_DEFAULT_SRC='self'
CSP_CONNECT_SRC='self',http://localhost:3000
CSP_IMG_SRC='self',data:,blob:
CSP_STYLE_SRC='self','unsafe-inline'
CSP_FONT_SRC='self',data:
CSP_SCRIPT_SRC='self'
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AUTH_LOGIN_LIMIT=10
AUTH_LOGIN_TTL_SEC=60
AUTH_LOGIN_BLOCK_AFTER=5
AUTH_LOGIN_BLOCK_SEC=900
AUTH_LOGIN_RESET_WINDOW_SEC=3600
AUTH_REGISTER_LIMIT=6
AUTH_REGISTER_TTL_SEC=300
AUTH_VERIFY_EMAIL_LIMIT=10
AUTH_VERIFY_EMAIL_TTL_SEC=900
AUTH_REFRESH_LIMIT=20
AUTH_REFRESH_TTL_SEC=300
AUTH_BOOTSTRAP_LIMIT=3
AUTH_BOOTSTRAP_TTL_SEC=300
DOCUMENT_UPLOAD_LIMIT=12
DOCUMENT_UPLOAD_TTL_SEC=60
PERMISSION_REQUEST_LIMIT=8
PERMISSION_REQUEST_TTL_SEC=300
AREA_REQUEST_LIMIT=8
AREA_REQUEST_TTL_SEC=300
ADMIN_REGISTRATION_ACTION_LIMIT=30
ADMIN_REGISTRATION_ACTION_TTL_SEC=60
ADMIN_PERMISSION_ACTION_LIMIT=40
ADMIN_PERMISSION_ACTION_TTL_SEC=60
SEARCH_REINDEX_LIMIT=5
SEARCH_REINDEX_TTL_SEC=60
ES_NODE=http://localhost:9200
ES_INDEX_DOCUMENTS=dms_documents
SEARCH_MODE=auto
SEARCH_INDEX_MAX_RETRIES=5
SEARCH_INDEX_RETRY_BASE_MS=2000
SEARCH_INDEX_RETRY_MAX_MS=30000
SEARCH_INDEX_WORKER_MS=3000
SEARCH_INDEX_BATCH_SIZE=10
OCR_ENABLED=true
OCR_TESSERACT_BIN=tesseract
OCR_PDFTOPPM_BIN=pdftoppm
OCR_LANGS=spa+eng
OCR_DPI=300
OCR_MAX_PAGES=10
OCR_TIMEOUT_MS=120000
TESSDATA_PREFIX=
FEATURE_FLAGS=audit-json-export,admin-analytics,notifications,saved-views,advanced-exports,dark-mode,i18n
BOOTSTRAP_TOKEN=
ALLOWED_EMAIL_DOMAIN=bsm.com.mx
EMAIL_MODE=console
VERIFICATION_CODE_TTL_MIN=15
VERIFICATION_MAX_ATTEMPTS=5
